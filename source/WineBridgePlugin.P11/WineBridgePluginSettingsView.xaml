<UserControl x:Class="WineBridgePlugin.WineBridgePluginSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WineBridgePlugin"
             xmlns:p="clr-namespace:Playnite"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:WineBridgePluginSettingsHandler}"
             d:DesignHeight="600" d:DesignWidth="800">

    <StackPanel>
        <TextBlock Text="{p:LocalizedString {x:Static p:LocId.example_string}}" Margin="4" />
        <TextBox Text="{Binding Settings.Property}" Margin="4" />
    </StackPanel>

</UserControl>